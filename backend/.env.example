# Copier ce fichier en .env et remplir les valeurs
#   cp .env.example .env

# ── Clé API Google Gemini (obligatoire) ───────
GOOGLE_API_KEY=your_google_api_key_here

# ── Modèles Gemini ────────────────────────────
MODEL_NAME=gemini-2.5-flash
MODEL_FALLBACK_1=gemini-2.0-flash
MODEL_FALLBACK_2=gemini-flash-lite-latest

# ── Paramètres OCR / LLM ─────────────────────
MAX_OCR_CHARS=15000
REQUIRE_TTC_LETTERS=true

# ── Tesseract ─────────────────────────────────
# Laisser vide en Docker (Tesseract est dans /usr/bin/tesseract sur Linux)
# Remplir uniquement pour un run local sur Windows :
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
